    "--wb-primary": "#6366f1",
    "--wb-primary-foreground": "#ffffff",
    "--wb-secondary": "rgba(99, 102, 241, 0.2)",
    "--wb-secondary-foreground": "#e0e7ff",
    "--wb-accent": "#22d3ee",
