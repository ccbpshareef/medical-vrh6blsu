{
  "schemaVersion": "1.0.0",
  "description": "Design tokens referenced by component variantPresets (token.* paths)",
  "fonts": {
    "sans": "var(--font-geist-sans), ui-sans-serif, system-ui, sans-serif",
    "mono": "var(--font-geist-mono), ui-monospace, monospace",
    "display": "var(--font-geist-sans), ui-sans-serif, system-ui, sans-serif"
  },
  "fontSizes": {
    "xs": "0.75rem",
    "sm": "0.875rem",
    "md": "1rem",
    "lg": "1.125rem",
    "xl": "1.25rem",
    "2xl": "1.5rem",
    "3xl": "1.875rem",
    "4xl": "2.25rem"
  },
  "fontWeights": {
    "normal": "400",
    "medium": "500",
    "semibold": "600",
    "bold": "700"
  },
  "lineHeights": {
    "tight": "1.25",
    "normal": "1.5",
    "relaxed": "1.625"
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem"
  },
  "radius": {
    "sm": "0.375rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "full": "9999px"
  },
  "colors": {
    "background": "var(--wb-background)",
    "foreground": "var(--wb-foreground)",
    "surface": "var(--wb-surface)",
    "card": "var(--wb-card)",
    "surfaceElevated": "var(--wb-surface-elevated)",
    "primary": "var(--wb-primary)",
    "primaryForeground": "var(--wb-primary-foreground)",
    "secondary": "var(--wb-secondary)",
    "secondaryForeground": "var(--wb-secondary-foreground)",
    "accent": "var(--wb-accent)",
    "muted": "var(--wb-muted)",
    "border": "var(--wb-border)",
    "success": "#22c55e",
    "warning": "#f59e0b",
    "danger": "var(--wb-danger)",
    "dangerForeground": "var(--wb-danger-foreground)",
    "info": "#38bdf8"
  },
  "gradients": {
    "primary": "var(--wb-gradient-primary)"
  },
  "shadows": {
    "xs": "0 1px 1px rgba(0, 0, 0, 0.2)",
    "sm": "0 1px 2px rgba(0, 0, 0, 0.25)",
    "md": "0 8px 24px rgba(0, 0, 0, 0.35)",
    "lg": "0 16px 48px rgba(0, 0, 0, 0.45)",
    "glass": "0 8px 32px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255,255,255,0.1)",
    "glossy": "var(--wb-shadow-glossy)",
    "glow": "var(--wb-shadow-glow)"
  },
  "focusRing": {
    "default": "var(--wb-focus-ring)"
  },
  "motion": {
    "instant": "0ms",
    "fast": "150ms",
    "normal": "250ms",
    "slow": "400ms",
    "slower": "600ms"
  },
  "effects": {
    "glossyGradient": "linear-gradient(180deg, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0.08) 100%)",
    "meshBackground": "radial-gradient(ellipse 80% 50% at 20% 40%, rgba(99,102,241,0.35), transparent), radial-gradient(ellipse 60% 40% at 80% 20%, rgba(34,211,238,0.2), transparent), radial-gradient(ellipse 50% 50% at 50% 100%, rgba(139,92,246,0.15), transparent)"
  }
}
